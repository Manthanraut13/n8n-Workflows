    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze the following contract text and extract ALL instances of these\nclause categories. For each, quote the EXACT relevant text from the\ncontract. If a clause is absent, set value to null.\n\nReturn this exact JSON schema:\n{\n  \"contract_type\": \"NDA | SERVICE_AGREEMENT | VENDOR | EMPLOYMENT | OTHER\",\n  \"parties\": { \"party_a\": \"string\", \"party_b\": \"string\" },\n  \"effective_date\": \"YYYY-MM-DD or null\",\n  \"payment_terms\": {\n    \"text\": \"exact quote or null\",\n    \"days\": \"integer or null\",\n    \"conditions\": \"string or null\"\n  },\n  \"liability\": {\n    \"text\": \"exact quote or null\",\n    \"cap_amount\": \"string or null\",\n    \"exclusions\": [\"string\"]\n  },\n  \"ip_ownership\": {\n    \"text\": \"exact quote or null\",\n    \"owner\": \"CLIENT | VENDOR | JOINT | UNSPECIFIED\",\n    \"work_for_hire\": \"boolean or null\"\n  },\n  \"termination\": {\n    \"text\": \"exact quote or null\",\n    \"notice_days\": \"integer or null\",\n    \"for_cause\": \"boolean or null\",\n    \"for_convenience\": \"boolean or null\"\n  },\n  \"renewal\": {\n    \"text\": \"exact quote or null\",\n    \"auto_renews\": \"boolean or null\",\n    \"notice_to_cancel_days\": \"integer or null\"\n  },\n  \"governing_law\": {\n    \"text\": \"exact quote or null\",\n    \"jurisdiction\": \"string or null\",\n    \"dispute_resolution\": \"ARBITRATION | LITIGATION | MEDIATION | null\"\n  },\n  \"confidentiality\": {\n    \"text\": \"exact quote or null\",\n    \"duration_years\": \"integer or null\",\n    \"mutual\": \"boolean or null\"\n  },\n  \"indemnification\": {\n    \"text\": \"exact quote or null\",\n    \"mutual\": \"boolean or null\"\n  },\n  \"missing_clauses\": [\"list of clause names not found in contract\"]\n}\n\nCONTRACT TEXT:\n{{ $('CONTENT HASH').item.json.cleaned_contract_text }}",
        "options": {
          "systemMessage": " You are a legal document analyst. Extract contract clauses with\nprecision. Return ONLY valid JSON. No markdown. No explanation."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        112,
        -48
      ],
      "id": "f35a6472-359e-47bf-a0a6-99a6b0775629",
      "name": "Clause Extraction AI"
    },
    {
      "parameters": {
        "jsCode": "// Safely extract AI response\nconst raw =\n  items[0]?.json?.choices?.[0]?.message?.content ||\n  items[0]?.json?.output ||\n  \"\";\n\n// Remove markdown code blocks\nconst clean = raw\n  .replace(/```json|```JSON|```js|```/g, \"\")\n  .trim();\n\nlet clauses;\n\ntry {\n  clauses = JSON.parse(clean);\n} catch (e) {\n  // Attempt recovery if JSON is embedded in text\n  const match = clean.match(/\\{[\\s\\S]*\\}/);\n  clauses = match ? JSON.parse(match[0]) : { parse_error: true, raw };\n}\n\n// Required clauses\nconst required = [\n  \"payment_terms\",\n  \"liability\",\n  \"ip_ownership\",\n  \"termination\",\n  \"renewal\",\n  \"governing_law\",\n  \"confidentiality\",\n  \"indemnification\"\n];\n\n// Detect missing clauses\nclauses.missing_fields = required.filter(\n  f => !clauses[f] || clauses[f]?.text === null\n);\n\nreturn [\n  {\n    json: {\n      ...items[0].json,\n      clauses\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        -48
      ],
      "id": "68bf63da-d44e-4be4-bd1a-0d6f4e1baad2",
      "name": "PARSE OUTPUT"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Compare the EXTRACTED CLAUSES against the STANDARD TEMPLATE below.\nScore each clause category: \"low\" | \"medium\" | \"high\" | \"critical\"\n\nRISK CRITERIA:\n  payment_terms: low=≤30 days, medium=31-60, high=61-90, critical=>90 or unclear\n  liability: low=uncapped mutual, medium=capped≥contract value, high=capped<50%,\n             critical=unilateral cap or none\n  ip_ownership: low=client owns all, medium=joint, high=vendor retains, critical=unspecified\n  termination: low=30-day notice both parties, medium=60-day, high=>90-day or one-sided,\n               critical=no termination clause\n  renewal: low=manual renewal required, medium=auto with 60+ day notice,\n           high=auto with <30 day notice, critical=auto with no notice period\n  governing_law: low=favorable jurisdiction, medium=neutral, high=unfavorable,\n                 critical=no governing law specified\n  compliance: low=GDPR/SOC2 referenced, medium=partial, high=missing key reqs,\n              critical=explicitly excludes compliance obligations\n\n\nEXTRACTED CONTRACT CLAUSES: {{ JSON.stringify($json.clauses) }}\n\nReturn this EXACT JSON (no other text):\n{\n  \"payment_terms_risk\": \"low|medium|high|critical\",\n  \"payment_terms_flag\": \"brief explanation of deviation from standard\",\n  \"liability_risk\": \"low|medium|high|critical\",\n  \"liability_flag\": \"string\",\n  \"ip_ownership_risk\": \"low|medium|high|critical\",\n  \"ip_ownership_flag\": \"string\",\n  \"termination_risk\": \"low|medium|high|critical\",\n  \"termination_flag\": \"string\",\n  \"renewal_risk\": \"low|medium|high|critical\",\n  \"renewal_flag\": \"string\",\n  \"governing_law_risk\": \"low|medium|high|critical\",\n  \"governing_law_flag\": \"string\",\n  \"compliance_risk\": \"low|medium|high|critical\",\n  \"compliance_flag\": \"string\",\n  \"missing_clause_penalties\": [\"list of high-risk missing clauses\"],\n  \"key_concerns\": [\"top 3 most important concerns as strings\"],\n  \"recommended_actions\": [\"list of specific negotiation points\"]\n}",
        "options": {
          "systemMessage": "=You are a legal risk assessment engine. You score contract clauses\nagainst a standard template. Return ONLY valid JSON. Be deterministic"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        624,
        -48
      ],
      "id": "f215cf06-3c58-4886-bbb4-94d1cea89f7b",
      "name": "Risk Analysis AI"
    },
    {
      "parameters": {
        "jsCode": "// Get raw output from previous node\nconst raw = items[0].json.output || \"\";\n\n// Remove markdown code blocks\nconst cleaned = raw\n  .replace(/```json|```JSON|```/g, \"\")\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (err) {\n  parsed = {\n    parse_error: true,\n    raw_output: raw\n  };\n}\n\n// Return parsed JSON\nreturn [\n  {\n    json: {\n      ...items[0].json,\n      risk_analysis: parsed\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        -48
      ],
      "id": "9dae106b-b474-4721-8bc7-f8197a22c44d",
      "name": "Parse Risk JSON"
    },
    {
      "parameters": {
        "jsCode": "// Safe access\nconst r = items[0]?.json?.risk_scores || {};\n\nconst weights = {\n  payment_terms_risk: 15,\n  liability_risk: 25,\n  ip_ownership_risk: 20,\n  termination_risk: 15,\n  renewal_risk: 10,\n  compliance_risk: 15\n};\n\nconst riskValues = {\n  low: 0,\n  medium: 40,\n  high: 75,\n  critical: 100\n};\n\nlet weightedSum = 0;\nlet totalWeight = 0;\n\nfor (const [key, weight] of Object.entries(weights)) {\n\n  // safe lookup\n  const riskLevel = r?.[key] || \"medium\";\n\n  const val = riskValues[riskLevel] ?? 40;\n\n  weightedSum += val * weight;\n  totalWeight += weight;\n}\n\nconst score = totalWeight\n  ? Math.round(weightedSum / totalWeight)\n  : 0;\n\nconst tier =\n  score < 30 ? \"GREEN\" :\n  score < 60 ? \"AMBER\" :\n  score < 80 ? \"RED\" :\n  \"CRITICAL\";\n\n// Missing clause penalty\nconst missing =\n  items[0]?.json?.clauses?.missing_fields?.length || 0;\n\nconst penalty = missing * 5;\n\nconst final_score = Math.min(100, score + penalty);\n\nreturn [{\n  json: {\n    ...items[0].json,\n    composite_score: final_score,\n    risk_tier: tier\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        -48
      ],
      "id": "13e6946b-51a4-4a55-864b-44cab1639207",
      "name": "Risk Scoring Engine"
    },
    {
      "parameters": {
        "jsCode": "const data = items[0].json;\nconst r = data.risk_analysis || {};\n\nlet summary = [];\n\nsummary.push(\"CONTRACT RISK SUMMARY\");\nsummary.push(\"----------------------------------\");\nsummary.push(`Overall Risk Tier: ${data.risk_tier}`);\nsummary.push(`Composite Risk Score: ${data.composite_score}/100`);\nsummary.push(\"\");\n\n// Clause level annotation\nconst clauses = [\n  \"payment_terms\",\n  \"liability\",\n  \"ip_ownership\",\n  \"termination\",\n  \"renewal\",\n  \"governing_law\",\n  \"compliance\"\n];\n\nclauses.forEach(c => {\n  const risk = r[`${c}_risk`] || \"unknown\";\n  const flag = r[`${c}_flag`] || \"No analysis available\";\n\n  summary.push(`• ${c.replace(\"_\",\" \").toUpperCase()}`);\n  summary.push(`  Risk Level: ${risk.toUpperCase()}`);\n  summary.push(`  Note: ${flag}`);\n  summary.push(\"\");\n});\n\n// Key concerns\nif (r.key_concerns?.length) {\n  summary.push(\"KEY CONCERNS:\");\n  r.key_concerns.forEach(c => summary.push(`- ${c}`));\n  summary.push(\"\");\n}\n\n// Recommended actions\nif (r.recommended_actions?.length) {\n  summary.push(\"RECOMMENDED ACTIONS:\");\n  r.recommended_actions.forEach(a => summary.push(`- ${a}`));\n  summary.push(\"\");\n}\n\nconst annotated_summary = summary.join(\"\\n\");\n\nreturn [{\n  json: {\n    ...data,\n    annotated_summary\n  }\n}];"
      },
