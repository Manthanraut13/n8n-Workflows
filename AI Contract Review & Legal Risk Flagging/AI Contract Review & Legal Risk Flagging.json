      "id": "99dc06f7-e73a-4b13-9dcb-05ec157994f8",
      "name": "CLEANED TEXT"
    },
    {
      "parameters": {
        "jsCode": "function simpleHash(str) {\n  let hash = 0;\n  if (!str) return hash;\n\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash |= 0; // Convert to 32bit integer\n  }\n\n  return Math.abs(hash).toString(16);\n}\n\nconst text = items[0].json.extracted_text;\n\nitems[0].json.content_hash = simpleHash(text);\n\nreturn items;"
      },
