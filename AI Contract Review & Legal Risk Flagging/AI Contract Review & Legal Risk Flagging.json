    {
      "parameters": {
        "jsCode": "// Get binary file from input item\nconst binaryData = items[0].binary.attachment_0;\n\n// Convert base64 binary to buffer\nconst buffer = Buffer.from(binaryData.data, 'base64');\n\n// Convert buffer to string (basic fallback extraction)\nconst text = buffer.toString('utf8');\n\nreturn [{\n  json: {\n    ...items[0].json,\n    file_name: binaryData.fileName,\n    mime_type: binaryData.mimeType,\n    file_size: binaryData.fileSize,\n    extracted_text: text.replace(/\\s+/g, ' ').trim(),\n    char_count: text.length,\n    extraction_method: \"buffer_utf8_fallback\"\n  }\n}];"
      },
