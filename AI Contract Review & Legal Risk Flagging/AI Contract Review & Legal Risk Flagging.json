        "jsCode": "const mammoth = require('mammoth');\nconst binary = items[0].binary.contractFile;\nconst buffer = Buffer.from(binary.data, 'base64');\n\nconst result = await mammoth.extractRawText({ buffer });\nreturn [{\n  json: {\n    ...items[0].json,\n    extracted_text: result.value.replace(/\\s+/g, ' ').trim(),\n    char_count: result.value.length,\n    warnings: result.messages,\n    extraction_method: 'mammoth'\n  }\n}];"
