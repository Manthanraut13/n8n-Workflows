        "jsCode": "// Parse the stringified array\nlet urls = [];\n\ntry {\n  urls = JSON.parse($input.item.json.urls_list);\n} catch (e) {\n  urls = [];\n}\n\n// Ensure we have an array\nif (!Array.isArray(urls)) {\n  urls = [];\n}\n\n// Assign URLs to different keys\nreturn {\n  json: {\n    url_1: urls[0] || \"\",\n    url_2: urls[1] || \"\",\n    url_3: urls[2] || \"\",\n    niche: $input.item.json.niche,\n    geo: $input.item.json.geo,\n    audience: $input.item.json.audience,\n    timestamp: $input.item.json.timestamp\n  }\n};\n"
