    {
      "parameters": {
        "jsCode": "let aiResponse = $input.item.json.output;\n\n// Sometimes AI wraps in markdown - strip it\nif (typeof aiResponse === 'string') {\n  aiResponse = aiResponse.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  aiResponse = JSON.parse(aiResponse);\n}\n\nreturn {\n  json: {\n    research_id: $('Set - Prepare Variables').item.json.research_id,\n    niche: $('Set - Prepare Variables').item.json.niche,\n    geo: $('Set - Prepare Variables').item.json.geo,\n    audience: $('Set - Prepare Variables').item.json.audience,\n    timestamp: new Date().toISOString(),\n    summary: aiResponse.summary,\n    top_trends: aiResponse.top_trends.join(' | '),\n    common_pain_points: aiResponse.common_pain_points.join(' | '),\n    opportunities: aiResponse.opportunities.join(' | '),\n    risks: aiResponse.risks.join(' | '),\n    recommended_focus_areas: aiResponse.recommended_focus_areas.join(' | ')\n  }\n};"
      },
