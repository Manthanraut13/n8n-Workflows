    {
      "parameters": {
        "jsCode": "const input = $input.all()[0].json;\n\n// Extract key indicators from project description\nconst description = input.project_description.toLowerCase();\n\n// Detect complexity level\nlet complexity = \"Medium\";\nif (description.includes(\"integration\") || description.includes(\"api\") || description.includes(\"custom\")) {\n  complexity = \"High\";\n} else if (description.includes(\"simple\") || description.includes(\"basic\")) {\n  complexity = \"Low\";\n}\n\n// Detect project type\nlet projectType = \"General Consulting\";\nif (description.includes(\"automation\") || description.includes(\"workflow\")) {\n  projectType = \"Automation Implementation\";\n} else if (description.includes(\"ai\") || description.includes(\"machine learning\")) {\n  projectType = \"AI/ML Solution\";\n} else if (description.includes(\"website\") || description.includes(\"web app\")) {\n  projectType = \"Web Development\";\n} else if (description.includes(\"integration\")) {\n  projectType = \"System Integration\";\n}\n\n// Estimate timeline based on complexity\nlet estimatedTimelineWeeks = 8;\nif (complexity === \"High\") estimatedTimelineWeeks = 12;\nif (complexity === \"Low\") estimatedTimelineWeeks = 4;\n\n// Industry-specific considerations\nconst industryKeywords = {\n  \"Healthcare\": [\"health\", \"medical\", \"patient\", \"clinic\", \"hospital\"],\n  \"Finance\": [\"finance\", \"banking\", \"payment\", \"transaction\", \"fintech\"],\n  \"E-commerce\": [\"ecommerce\", \"shop\", \"store\", \"retail\", \"marketplace\"],\n  \"Education\": [\"education\", \"learning\", \"course\", \"student\", \"university\"],\n  \"Real Estate\": [\"property\", \"real estate\", \"rental\", \"listing\"]\n};\n\nlet detectedIndustry = input.industry || \"General\";\nfor (const [industry, keywords] of Object.entries(industryKeywords)) {\n  if (keywords.some(keyword => description.includes(keyword))) {\n    detectedIndustry = industry;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...input,\n    enriched_data: {\n      complexity: complexity,\n      project_type: projectType,\n      estimated_timeline_weeks: estimatedTimelineWeeks,\n      detected_industry: detectedIndustry,\n      urgency: input.timeline_expectations.toLowerCase().includes(\"urgent\") ? \"High\" : \"Normal\"\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        592,
        -16
      ],
      "id": "17ae68ac-f9d4-476f-8930-ee70ddd28dde",
      "name": "Function (Enrich Context)"
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"ai_context\" : \"\n        Client: {{ $json.client_name }} from {{ $json.company_name }}\n        Industry: {{ $json.enriched_data.detected_industry }}\n\n        Project Type: {{ $json.enriched_data.project_type }}\n        Complexity: {{ $json.enriched_data.complexity }}\n        PROJECT REQUIREMENTS: {{ $json.project_description }}\n  \n        CONSTRAINTS:\n        Budget Range: {{ $json.budget_range }}\n        Timeline Expectations: {{ $json.timeline_expectations }}\n        Estimated Duration: {{ $json.enriched_data.estimated_timeline_weeks }} weeks\n\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
