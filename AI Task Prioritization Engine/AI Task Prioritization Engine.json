    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n\n  // Tasks array (already enriched)\n  const tasks = Array.isArray(data.tasks) ? data.tasks : [];\n  const summary = data.summary || {};\n\n  const date =\n    data.execution_timestamp ||\n    tasks[0]?.date_prioritized ||\n    new Date().toISOString().split(\"T\")[0];\n\n  let message = `📋 *Daily Task Prioritization Report*\\n`;\n  message += `Date: ${date}\\n\\n`;\n\n  // ---- Summary ----\n  message += `📊 *Summary*\\n`;\n  message += `🔴 High Priority: ${summary.high_priority_count ?? 0}\\n`;\n  message += `🟡 Medium Priority: ${summary.medium_priority_count ?? 0}\\n`;\n  message += `🟢 Low Priority: ${summary.low_priority_count ?? 0}\\n\\n`;\n\n  // ---- Top tasks ----\n  message += `⭐ *Top Tasks to Focus On*\\n`;\n\n  if (summary.top_3_tasks && summary.top_3_tasks.length > 0) {\n    summary.top_3_tasks.forEach((task, idx) => {\n      message += `${idx + 1}. *${task.name}*\\n   → ${task.reason}\\n`;\n    });\n  } else if (tasks.length > 0) {\n    // Fallback: use top ranked tasks\n    tasks.slice(0, 3).forEach((task, idx) => {\n      message += `${idx + 1}. *${task.task_name}*\\n   → ${task.reasoning}\\n`;\n    });\n  } else {\n    message += `• No tasks available\\n`;\n  }\n\n  // ---- Deferred ----\n  message += `\\n⏸️ *Can Be Deferred*\\n`;\n  if (summary.deferred_tasks && summary.deferred_tasks.length > 0) {\n    summary.deferred_tasks.slice(0, 3).forEach(task => {\n      message += `• ${task}\\n`;\n    });\n  } else {\n    message += `• None\\n`;\n  }\n\n  // ---- Droppable ----\n  message += `\\n🗑️ *Consider Dropping*\\n`;\n  if (summary.droppable_tasks && summary.droppable_tasks.length > 0) {\n    summary.droppable_tasks.slice(0, 3).forEach(task => {\n      message += `• ${task}\\n`;\n    });\n  } else {\n    message += `• None\\n`;\n  }\n\n  message += `\\n📌 Full results saved to Google Sheets.`;\n\n  // 1 input → 1 output\n  results.push({\n    json: {\n      notification_message: message,\n      execution_date: date\n    }\n  });\n}\n\nreturn results;"
      },
