    {
      "parameters": {
        "jsCode": "// Get all incoming items (each contains an AI response)\nconst items = $input.all();\n\n// Today date (ISO, date-only)\nconst timestamp = new Date().toISOString().split(\"T\")[0];\n\nconst results = [];\n\nfor (const item of items) {\n  // AI response comes as a STRING inside `output`\n  if (!item.json.output) {\n    throw new Error(\"Missing AI output in input item\");\n  }\n\n  let aiResponse;\n  try {\n    aiResponse = JSON.parse(item.json.output);\n  } catch (err) {\n    throw new Error(\"AI output is not valid JSON\");\n  }\n\n  // Validate structure\n  if (\n    !aiResponse.prioritized_tasks ||\n    !Array.isArray(aiResponse.prioritized_tasks)\n  ) {\n    throw new Error(\"Invalid AI response structure: prioritized_tasks missing\");\n  }\n\n  // Enrich tasks\n  const enrichedTasks = aiResponse.prioritized_tasks.map((task, idx) => ({\n    rank: idx + 1,\n    task_name: task.task_name,\n    priority_level: task.priority_level,\n    urgency_score: task.urgency_score,\n    impact_score: task.impact_score,\n    effort_score: task.effort_score,\n    strategic_value_score: task.strategic_value_score,\n    composite_score: task.composite_score,\n    reasoning: task.reasoning,\n    recommendation: task.recommendation,\n    date_prioritized: timestamp\n  }));\n\n  // Push ONE output item per input item\n  results.push({\n    json: {\n      tasks: enrichedTasks,\n      summary: aiResponse.summary || {},\n      execution_timestamp: timestamp\n    }\n  });\n}\n\nreturn results;"
      },
