    {
      "parameters": {
        "jsCode": "// Mode: Run Once for All Items\nconst items = $input.all();\nconst xmlString = items[0].json.data || items[0].json.body || '';\nconst articleMatches = xmlString.match(/<item>([\\s\\S]*?)<\\/item>/g) || [];\nconst leads = articleMatches.slice(0, 20).map((block, i) => {\n  const title = ((block.match(/<title>([\\s\\S]*?)<\\/title>/) || [])[1] || '')\n    .replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim();\n  const link = ((block.match(/<link>([\\s\\S]*?)<\\/link>/) || [])[1] || '').trim();\n  const source = ((block.match(/<source[^>]*>([\\s\\S]*?)<\\/source>/) || [])[1] || '')\n    .replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim();\n  return { json: {\n    lead_index: i + 1, article_title: title, publication: source,\n    article_url: link, source_type: 'google_news_rss',\n    name: '', email: '', beat: ''\n  }};\n});\nreturn leads.length > 0 ? leads : [{ json: { no_results: true } }];"
      },
