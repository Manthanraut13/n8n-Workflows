    {
      "parameters": {
        "jsCode": "let content = $json.output || $json.text || \"\";\n\n// Remove markdown if exists\ncontent = content.replace(/```json|```/g, \"\").trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  return [{\n    json: {\n      error: \"Invalid JSON from AI\",\n      raw: content\n    }\n  }];\n}\n\nreturn [{ json: parsed }];"
      },
