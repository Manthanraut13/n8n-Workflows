    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nlet rawOutput = item.output || item.text || '';\nlet emailData = {};\n\n// 🧹 Step 1: Clean raw output safely\nif (typeof rawOutput === 'string') {\n  rawOutput = rawOutput\n    .replace(/```json|```/g, '')\n    .trim();\n}\n\n// 🛡 Step 2: Safe JSON parse\ntry {\n  emailData = JSON.parse(rawOutput);\n} catch (e) {\n  emailData = {\n    subject_line: `Press Release: ${item.company_name || ''}`,\n    email_body: 'Please see attached press release.',\n    personalization_note: '',\n    parse_error: true,\n    raw_output: rawOutput // 🔥 for debugging\n  };\n}\n\n// ✨ Step 3: Clean fields\nconst subject = (emailData.subject_line || '').trim();\nconst body = (emailData.email_body || '').trim();\nconst note = (emailData.personalization_note || '').trim();\n\n// 📧 Step 4: Better email validation\nconst recipientEmail = (\n  item.email ||\n  item.journalist_email ||\n  ''\n).trim();\n\nconst isValidEmail = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(recipientEmail);\n\n// 👤 Step 5: Name fallback\nconst recipientName =\n  item.name ||\n  item.journalist_name ||\n  'there';\n\n// 🚀 Final output\nreturn {\n  json: {\n    ...item,\n\n    subject_line: subject,\n    email_body: body,\n    personalization_note: note,\n\n    recipient_email: recipientEmail,\n    recipient_name: recipientName,\n\n    email_valid: isValidEmail && subject.length > 0,\n\n    // 🔥 Debug flags\n    parse_error: emailData.parse_error || false\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2256,
        -96
      ],
      "id": "b2db6372-67eb-4250-8e72-113c51c80ffb",
      "name": "Parse Pitch Email"
    },
    {
      "parameters": {
        "jsCode": "// Mode: Run Once for All Items\nconst all = $input.all();\nconst sent = all.filter(i => i.json.email_status === 'sent').length;\nconst skipped = all.filter(i => i.json.email_status === 'skipped').length;\nconst avg = all.reduce((s,i) => s + (i.json.relevance_score||0), 0) / (all.length||1);\nreturn { json: {\n  campaign_id: all[0]?.json?.campaign_id || '',\n  total_journalists_scored: all.length,\n  emails_sent: sent, emails_skipped: skipped,\n  average_relevance_score: Math.round(avg * 10) / 10,\n  run_completed_at: new Date().toISOString(),\n  status: sent > 0 ? 'success' : 'no_emails_sent'\n}};"
      },
