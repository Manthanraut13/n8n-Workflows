        "jsCode": "const item = $input.first().json;\nlet scoreData = { relevance_score: 0, match_reason: '', suggested_angle: '' };\ntry {\n  scoreData = JSON.parse((item.output || '').replace(/```json|```/g, '').trim());\n} catch(e) {}\nreturn {\n  json: { ...item, relevance_score: Number(scoreData.relevance_score) || 0,\n    match_reason: scoreData.match_reason || '',\n    suggested_angle: scoreData.suggested_angle || '' }\n};"
