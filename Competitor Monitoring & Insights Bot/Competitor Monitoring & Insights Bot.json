    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze changes for: {{ $json.company_context.parseJson().company_name }}\n\nWebsite: {{ $json.company_context.parseJson().website_url }}\n\nContent snapshot:\n{{ $json.content_snapshot }}\n\nRSS Headlines (if any):\n{{ $json.company_context.parseJson().rss_feed_url }}\n\nProvide competitive intelligence in JSON format.",
        "options": {
          "systemMessage": "=You are a competitive intelligence analyst. Analyze website content changes and provide actionable business insights.\n\nYour task:\n1. Identify what specifically changed (new products, pricing, messaging, features, blog topics)\n2. Assess the strategic significance (low/medium/high)\n3. Explain potential business impact\n4. Recommend response actions\n\nOutput ONLY valid JSON with this exact structure:\n{\n  \"changes_detected\": [\"change 1\", \"change 2\", \"change 3\"],\n  \"significance_level\": \"low|medium|high\",\n  \"business_impact\": \"Brief explanation of what this means for our business\",\n  \"key_insights\": [\"insight 1\", \"insight 2\"],\n  \"recommended_actions\": [\"action 1\", \"action 2\"],\n  \"summary\": \"One-sentence summary of the change\"\n}\n\nBe concise. Focus on strategic implications, not technical details."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        -80,
        160
      ],
      "id": "bb608aa7-e3fc-4e92-b790-27c93b51bf7d",
      "name": "AI Analysis Agent"
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.item.json.output || '';\n\n// Extract JSON from potential markdown code blocks\nlet jsonText = aiResponse;\nconst jsonMatch = aiResponse.match(/```json\\s*([\\s\\S]*?)\\s*```/);\nif (jsonMatch) {\n  jsonText = jsonMatch[1];\n} else {\n  // Try to find JSON object directly\n  const directMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  if (directMatch) {\n    jsonText = directMatch[0];\n  }\n}\n\ntry {\n  const insights = JSON.parse(jsonText);\n  \n  return {\n    json: {\n      company_name: $input.item.json.company_name,\n      website_url: $input.item.json.website_url,\n      timestamp: $input.item.json.timestamp,\n      current_hash: $input.item.json.current_hash,\n      changes_detected: insights.changes_detected || [],\n      significance_level: insights.significance_level || 'medium',\n      business_impact: insights.business_impact || '',\n      key_insights: insights.key_insights || [],\n      recommended_actions: insights.recommended_actions || [],\n      summary: insights.summary || 'Content changed on competitor website'\n    }\n  };\n} catch (error) {\n  // Fallback if JSON parsing fails\n  return {\n    json: {\n      company_name: $input.item.json.company_name,\n      website_url: $input.item.json.website_url,\n      timestamp: $input.item.json.timestamp,\n      current_hash: $input.item.json.current_hash,\n      changes_detected: ['Unable to parse AI response'],\n      significance_level: 'medium',\n      business_impact: 'Manual review needed',\n      key_insights: [],\n      recommended_actions: [],\n      summary: 'Content changed - AI analysis failed'\n    }\n  };\n}"
      },
