      "name": "Fetch Website Content",
      "executeOnce": true
    },
    {
      "parameters": {
        "jsCode": "// Extract meaningful text from HTML\nconst html = $input.item.json.data || '';\nconst rss = $input.item.json.rss_data || '';\n\n// Clean HTML\nconst cleanText = html\n  .replace(/<script\\b[^<]*(?:(?!<\\/script>)<[^<]*)*<\\/script>/gi, '')\n  .replace(/<style\\b[^<]*(?:(?!<\\/style>)<[^<]*)*<\\/style>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .substring(0, 15000);\n\n// Extract RSS headlines\nconst rssHeadlines = rss\n  .match(/<title>(.*?)<\\/title>/g)\n  ?.map(t => t.replace(/<\\/?title>/g, ''))\n  .slice(0, 10)\n  .join(' | ') || '';\n\n// ✅ Pure JS hash (n8n-safe)\nfunction hashString(str) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    hash = (hash << 5) - hash + str.charCodeAt(i);\n    hash |= 0; // Convert to 32-bit integer\n  }\n  return hash.toString();\n}\n\nconst contentHash = hashString(cleanText);\n\nreturn {\n  json: {\n    company_name: $input.item.json.company_name,\n    website_url: $input.item.json.website_url,\n    cleaned_text: cleanText,\n    rss_headlines: rssHeadlines,\n    current_hash: contentHash,\n    previous_hash: $input.item.json.last_checked_hash || '',\n    timestamp: new Date().toISOString()\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
