      "id": "48a5981b-068c-49bd-bc61-b4b03d9e7c9f",
      "name": "extract content in xml"
    },
    {
      "parameters": {
        "operation": "xml",
        "options": {}
      },
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        416,
        144
      ],
      "id": "63482646-8f6d-4f9b-b697-59a47d3aebcf",
      "name": "Extract from xml"
    },
    {
      "parameters": {
        "jsCode": "const xml = items[0].json.data.toString('utf8');\n\n// 1. Grab every <w:p> block (paragraph)\nconst paraRegex = /<w:p[^>]*?>([\\s\\S]*?)<\\/w:p>/g;\n// 2. Grab every <w:t> (text run) inside\nconst wTRegex   = /<w:t[^>]*?>(.*?)<\\/w:t>/g;\n\nlet textOutput = '';\nlet pMatch;\n\nwhile ((pMatch = paraRegex.exec(xml))) {\n  const inner = pMatch[1];\n  let paragraph = '';\n\n  let tMatch;\n  while ((tMatch = wTRegex.exec(inner))) {\n    paragraph += tMatch[1];\n  }\n\n  paragraph = paragraph.replace(/\\s+/g, ' ').trim();\n  if (paragraph) {\n    textOutput += paragraph + '\\n\\n';\n  }\n}\n\nreturn [{\n  json: {\n    text: textOutput.trim()\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        144
      ],
      "id": "c7134d51-72bc-426a-b7b7-3620bbfcd59e",
      "name": "Parse xml to required text"
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
