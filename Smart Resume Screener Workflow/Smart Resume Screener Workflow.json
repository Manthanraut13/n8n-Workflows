      ],
      "id": "b82f851b-aba2-4386-8300-d73fe3fd1aba",
      "name": "Merge mail and docx content"
    },
    {
      "parameters": {
        "jsCode": "// DOCX-only final combiner\n\nconst input = $input.item;\n\n// 🔐 Get email metadata\nconst email = input.json;\n\nlet senderEmail = '';\nlet senderName = '';\n\nif (email.from?.value?.[0]) {\n  senderEmail = email.from.value[0].address || '';\n  senderName  = email.from.value[0].name || '';\n} else {\n  senderEmail = email.from?.text || '';\n}\n\n// Timestamp normalize\nconst timestamp = email.date && !isNaN(Date.parse(email.date))\n  ? new Date(email.date).toISOString()\n  : new Date().toISOString();\n\n// 🔍 Extract attachment binary\nif (!input.binary) {\n  throw new Error('❌ No attachment binary found');\n}\n\nconst binaryKey = Object.keys(input.binary)[0];\nconst bin = input.binary[binaryKey];\n\n// 📌 DOCX extracted text is inside email.text\n// Gmail triggers try to flatten docx into text automatically\nconst resumeText = email.text?.trim() || '';\n\nif (!resumeText) {\n  throw new Error('❌ No resume text extracted from DOCX (email.text empty)');\n}\n\nreturn [\n  {\n    json: {\n      candidateEmail: senderEmail,\n      candidateName: senderName,\n      emailSubject: email.subject || '',\n      emailBody: email.html || email.textAsHtml || email.text || '',\n      receivedDate: timestamp,\n      messageId: email.messageId || '',\n      threadId: email.threadId || '',\n\n      // Attachment metadata\n      fileName: bin.fileName || 'unknown',\n      mimeType: bin.mimeType || '',\n      fileExtension: (bin.fileName || '').split('.').pop(),\n\n      // Actual usable text\n      resumeText,\n    },\n    binary: {\n      [binaryKey]: bin\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
