    {
      "parameters": {
        "promptType": "define",
        "text": "=JOB TITLE: {{ $json.jobTitle }}\n\nJOB DESCRIPTION:{{ $json.jobDescription }}\n\n\nREQUIRED SKILLS:{{ $json.jobDescription }}\n\n\n---\n\nCANDIDATE RESUME:{{ $json.resumeText }}",
        "options": {
          "systemMessage": "=You are an expert HR recruiter tasked with evaluating candidate resumes against job descriptions.\n\nAnalyze the provided resume and job description, then return a structured evaluation in the following JSON format:\n\n{\n  \"timestamp\": {{ $json.receivedDate }},\n  \"candidateEmail\": {{ $json.candidateEmail }},\n  \"fileName\": {{ $json.fileName }},\n  \"jobTitle\": {{ $json.jobTitle }},\n  \"overallScore\": <number 0-100>,\n  \"matchLevel\": \"<EXCELLENT|GOOD|MODERATE|POOR>\",\n  \"experienceMatch\": <number 0-100>,\n  \"skillsMatch\": <number 0-100>,\n  \"educationMatch\": <number 0-100>,\n  \"keyStrengths\": [\"strength1\", \"strength2\", \"strength3\"],\n  \"missingRequirements\": [\"requirement1\", \"requirement2\"],\n  \"recommendInterview\": <true|false>,\n  \"summary\": \"<2-3 sentence evaluation>\",\n  \"redFlags\": [\"flag1 if any\"]\n}\n\nBe objective, thorough, and fair in your assessment."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        1024,
