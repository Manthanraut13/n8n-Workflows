    {
      "parameters": {
        "jsCode": "const allInputs = $input.all();\n\n// Identify Gmail vs Extract nodes\nlet emailData = null;\nlet fileExtract = null;\nlet binaryData = null;\n\nfor (const item of allInputs) {\n  // Extract node always has numpages OR info\n  if (item.json.numpages !== undefined || item.json.info !== undefined) {\n    fileExtract = item.json;\n  } else {\n    emailData = item.json;\n    binaryData = item.binary ?? null;\n  }\n}\n\nif (!emailData) throw new Error('❌ Missing Gmail metadata input');\nif (!fileExtract) throw new Error('❌ Missing Extract From File input');\nif (!binaryData) throw new Error('❌ Missing email binary attachment');\n\n// Extract attachment binaryKey\nconst binaryKey = Object.keys(binaryData)[0];\nconst bin = binaryData[binaryKey];\n\n// Extract sender email cleanly\nlet senderEmail = '';\nlet senderName = '';\nif (emailData.from?.value?.[0]) {\n  senderEmail = emailData.from.value[0].address || '';\n  senderName = emailData.from.value[0].name || '';\n} else {\n  senderEmail = emailData.from?.text || '';\n}\n\n// Clean date-safe\nlet timestamp;\nif (emailData.date && !isNaN(Date.parse(emailData.date))) {\n  timestamp = new Date(emailData.date).toISOString();\n} else {\n  timestamp = new Date().toISOString();\n}\n\nreturn [\n  {\n    json: {\n      // EMAIL FIELDS\n      candidateEmail: senderEmail,\n      candidateName: senderName,\n      emailSubject: emailData.subject || '',\n      emailBody: emailData.text || '',\n      receivedDate: timestamp,\n      messageId: emailData.messageId || '',\n      threadId: emailData.threadId || '',\n      \n      // FILE METADATA\n      fileName: bin.fileName || 'unknown',\n      mimeType: bin.mimeType || '',\n      fileExtension: (bin.fileName || '').split('.').pop(),\n\n      // EXTRACTED RESUME TEXT\n      resumeText: fileExtract.text || '',\n      pages: fileExtract.numpages || 1,\n\n      // INTERNAL META\n      pdfInfo: fileExtract.info || {}\n    },\n    binary: {\n      [binaryKey]: bin\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        -432
      ],
      "id": "da3bd441-b2c0-4d44-9859-fcf5cd90b888",
      "name": "Parse required field"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n  const binKeys = Object.keys(item.binary || {});\n\n  if (binKeys.length === 0) continue;   // No binary → skip\n\n  const key = binKeys[0];              // First binary key: attachment_0, attachment_1 etc\n  const bin = item.binary[key];\n\n  // Fix extension safely\n  if (bin.fileName) {\n    bin.fileName = bin.fileName.replace(/\\.docx$/i, '.zip');\n  }\n\n  // Update metadata\n  bin.fileExtension = 'zip';\n  bin.mimeType = 'application/zip';\n}\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
