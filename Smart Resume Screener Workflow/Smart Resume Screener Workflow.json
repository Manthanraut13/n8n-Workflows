      ],
      "id": "07b72f80-be42-4312-aac5-28d0af787452",
      "name": "AI Agent to evaluate resume"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const raw = item.json.output || '';\n\n  let cleaned = raw;\n\n  // Remove ```json and ``` if present\n  cleaned = cleaned.replace(/```json/i, '').replace(/```/g, '').trim();\n\n  let parsed;\n  try {\n    parsed = JSON.parse(cleaned);\n  } catch (e) {\n    parsed = {\n      timestamp: new Date().toISOString(),\n      candidateEmail: '',\n      fileName: '',\n      jobTitle: '',\n      overallScore: 0,\n      matchLevel: 'ERROR',\n      experienceMatch: 0,\n      skillsMatch: 0,\n      educationMatch: 0,\n      keyStrengths: [],\n      missingRequirements: [],\n      recommendInterview: false,\n      summary: 'Failed to parse JSON',\n      redFlags: []\n    };\n  }\n\n  results.push({\n    json: {\n      timestamp: parsed.timestamp,\n      candidateEmail: parsed.candidateEmail,\n      fileName: parsed.fileName,\n      jobTitle: parsed.jobTitle,\n\n      overallScore: parsed.overallScore,\n      matchLevel: parsed.matchLevel,\n      experienceMatch: parsed.experienceMatch,\n      skillsMatch: parsed.skillsMatch,\n      educationMatch: parsed.educationMatch,\n\n      keyStrengths: parsed.keyStrengths?.join('; ') || '',\n      missingRequirements: parsed.missingRequirements?.join('; ') || '',\n      recommendInterview: parsed.recommendInterview,\n      summary: parsed.summary,\n      redFlags: parsed.redFlags?.join('; ') || 'None'\n    }\n  });\n}\n\nreturn results;\n"
      },
